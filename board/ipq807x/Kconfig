       default "ipq807x"

config IPQ_I2C
	bool "Enable i2c support on IPQ platform"

config USB_XHCI_IPQ
	bool "ipq807x usb support for ipq807x"

config PCI_IPQ
	bool "ipq807x pci support for ipq807x"

config QCA_AQUANTIA_PHY
	bool "Enable Aquantia PHY support for ipq807x"

config QCA8033_PHY
	bool "Enable QCA8033 PHY support for ipq807x"

config QCA8081_PHY
	bool "Enable QCA8081 PHY support for ipq807x"

config QCA8075_PHY
	bool "Enable QCA8075 PHY support for ipq807x"

config BOARD_TYPES
	bool "Support board_type member in global data"
	default y

config LIST_OF_CONFIG_NAMES_SUPPORT
	bool "List of config names support"

config LIST_FUSE
	bool "Enable fuse list command"
	default n

config IPQ807X_AP8220
	bool "IPQ807x AP8220 board support"
	default n
	help
	  Enable support for IPQ807x AP8220 board

config IPQ807X_AX6
	bool "IPQ807x AX6 board support"
	default n
	help
	  Enable support for IPQ807x AX6 board

config IPQ807X_XGLINK_5GCPE
	bool "IPQ807x XGLINK 5GCPE board support"
	default n
	help
	  Enable support for IPQ807x XGLINK 5GCPE board
config IPQ807X_SOFTBANK_AIR5
	bool "IPQ807x SoftBank Air5 board support"
	default n
	help
	  Enable support for SoftBank Air5 (IPQ8072A) board.
	  Uses W25R512NWEIQ 64MB SPI-NOR flash.

config SOFTBANK_AIR5_BOOT
	bool "SoftBank Air5 direct OpenWrt boot"
	depends on IPQ807X_SOFTBANK_AIR5
	default n
	help
	  Enable Air5-specific boot command (bootopenwrt) and
	  web failsafe recovery via built-in httpd.
	  Replaces bootipq with direct FIT image boot from 0x00400000.

config DISABLE_SIGNED_BOOT
	bool "Disable Qualcomm signed boot verification"
	default n
	help
	  Skip SCM-based signature verification on APPSBL load.
	  Required for custom U-Boot on devices without secure boot fuses blown.
